{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 0,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "gcc",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/gcc",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "/usr/gcc/bin/g++",
                "CMAKE_CXX_FLAGS": "-DLOCAL -march=native -fno-exceptions -fno-rtti",
                "CMAKE_CXX_LINK_FLAGS": "-Wl,-rpath,/usr/gcc/lib64"
            }
        },
        {
            "name": "llvm",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-DLOCAL -march=native -fno-exceptions -fno-rtti -stdlib=libc++",
                "CMAKE_CXX_LINK_FLAGS": "-fuse-ld=lld -lc++abi"
            }
        }
    ]
}
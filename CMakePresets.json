{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 0,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "llvm",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-march=native -fno-exceptions -fno-rtti -DMODULE -stdlib=libc++",
                "CMAKE_CXX_LINK_FLAGS": "-fuse-ld=lld -lc++abi"
            }
        }
    ]
}